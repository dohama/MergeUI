# ============================================
# OozeUi Environment Variables
# 이 파일을 복사하여 .env로 만들고 실제 값을 입력하세요
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemonsqueezy
LEMON_API_KEY=your-lemon-api-key
LEMON_WEBHOOK_SECRET=your-webhook-secret
LEMON_STORE_ID=your-store-id

# Lemonsqueezy variant whitelist (D-17) — checkout.js에서 허용할 variant ID 3종
# 미일치 시 400 Invalid variant_id 응답. 미설정 시 checkout 자체 차단.
LEMON_VARIANT_PRO_MONTHLY=
LEMON_VARIANT_PRO_ANNUAL=
LEMON_VARIANT_EARLYBIRD=

# Loops (이메일 자동화)
LOOPS_API_KEY=your-loops-api-key

# Server
PORT=4000
NODE_ENV=development

# CORS — 추가 허용 Origin (콤마 구분, 선택)
# 기본 화이트리스트: https://mergeui.com, https://www.mergeui.com, *.vercel.app
# 비프로덕션(NODE_ENV != production)에서는 localhost 자동 허용
# Vercel preview 차단하려면 CORS_DISABLE_VERCEL_PREVIEW=1
CORS_ALLOWED_ORIGINS=
# (legacy 단일 도메인 fallback — 신규는 CORS_ALLOWED_ORIGINS 사용 권장)
CORS_ORIGIN=http://localhost:3000

# CSRF — 추가 허용 Origin (콤마 구분, 선택)
# 기본 화이트리스트: https://mergeui.com, https://www.mergeui.com, *.vercel.app
# 비프로덕션(NODE_ENV != production)에서는 localhost 자동 허용
CSRF_ALLOWED_ORIGINS=

# Sentry (선택)
SENTRY_DSN=

# Loops 트랜잭셔널 ID (문의 알림)
LOOPS_TID_INQUIRY=
ADMIN_EMAIL=

# JWT 검증은 Supabase Auth(supabase-js / GoTrue)가 자동 처리하므로 별도 시크릿 불필요.
# 과거 JWT_SECRET 변수는 코드 어디에서도 참조하지 않아 제거 (D-13, 2026-05-01).
